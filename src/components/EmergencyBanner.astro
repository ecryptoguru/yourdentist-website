---
import { clinicInfo } from '@/lib/data';
---

<div
  id="emergency-banner"
  class="fixed top-0 left-0 right-0 z-40 bg-teal-900/95 dark:bg-teal-950/95 backdrop-blur-sm text-white transition-transform duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center gap-3 py-2 text-sm">
      <span class="relative flex h-2 w-2">
        <span class="pulse-ring absolute inline-flex h-full w-full rounded-full bg-red-400"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
      </span>
      <span class="text-teal-50">
        <span class="font-medium">Dental Emergency?</span>
        <span class="text-teal-200 hidden sm:inline"> We're available for urgent care.</span>
      </span>
      <a
        href={clinicInfo.phoneLink}
        class="text-white font-medium underline underline-offset-2 hover:text-teal-200 transition-colors"
      >
        {clinicInfo.phone}
      </a>
    </div>
  </div>
</div>

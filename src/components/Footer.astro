---
import { clinicInfo, navLinks, serviceList } from '@/lib/data';
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 dark:bg-black text-slate-400 relative overflow-hidden">
  <!-- Top accent line -->
  <div class="h-1 bg-linear-to-r from-teal-700 via-teal-600 to-amber-500"></div>
  <!-- Ambient glow -->
  <div class="glow-orb w-[400px] h-[400px] bg-teal-900/20 dark:bg-teal-800/10 top-[10%] left-[5%]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand Column -->
      <div>
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-9 h-9 bg-teal-700 rounded-lg flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-white" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C8.5 2 6 4.5 6 8c0 2.5 1.5 5 3 7.5C10.5 18 11 20 12 20s1.5-2 3-4.5c1.5-2.5 3-5 3-7.5 0-3.5-2.5-6-6-6z" />
              <path d="M12 8v4" />
              <circle cx="12" cy="8" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-base text-white block leading-tight">YourDentist</span>
            <span class="text-teal-400 text-[11px] tracking-wide uppercase">Laser Dental Clinic</span>
          </div>
        </div>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6 leading-[1.7]">
          Advanced laser dental care in Bhubaneswar. Your smile is our passion. Experience painless treatments with cutting-edge technology.
        </p>
        <a href={clinicInfo.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-premium bg-teal-700 hover:bg-teal-600 text-white gap-2 rounded-lg h-10 text-sm font-medium transition-all duration-300 inline-flex items-center justify-center px-4">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            Book via WhatsApp
        </a>
        <div class="flex items-center gap-3 mt-6">
          <a href={clinicInfo.mapUrl} target="_blank" rel="noopener noreferrer" aria-label="Find us on Google Maps" class="w-9 h-9 bg-slate-800 dark:bg-warm-800 hover:bg-teal-700 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-slate-300 dark:text-warm-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" /></svg>
          </a>
          <a href="https://www.facebook.com/yourdentistpro" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="w-9 h-9 bg-slate-800 dark:bg-warm-800 hover:bg-teal-700 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-slate-300 dark:text-warm-400" viewBox="0 0 24 24" fill="currentColor"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.393-.061 5.64 5.64 0 0 0-.776-.061c-1.586 0-2.424.717-2.424 2.06v1.437h3.25l-.5 3.667h-2.75v8.018c4.838-.69 8.566-4.837 8.566-9.877C22.5 6.715 18.536 2.75 13.625 2.75S4.75 6.715 4.75 11.625c0 5.04 3.728 9.187 8.351 9.876v.001z" /></svg>
          </a>
          <a href="https://www.instagram.com/yourdentistpro" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="w-9 h-9 bg-slate-800 dark:bg-warm-800 hover:bg-teal-700 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-slate-300 dark:text-warm-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" x2="17.51" y1="6.5" y2="6.5" /></svg>
          </a>
          <a href="https://youtube.com/@yourdentistclinic" target="_blank" rel="noopener noreferrer" aria-label="Subscribe to our YouTube channel" class="w-9 h-9 bg-slate-800 dark:bg-warm-800 hover:bg-teal-700 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-slate-300 dark:text-warm-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17" /><path d="m10 15 5-3-5-3z" fill="currentColor" /></svg>
          </a>
          <a href="https://twitter.com/yourdentistpro" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Twitter" class="w-9 h-9 bg-slate-800 dark:bg-warm-800 hover:bg-teal-700 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-slate-300 dark:text-warm-400" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-5 text-[15px]">Quick Links</h3>
        <ul class="space-y-1">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="block py-2 text-slate-500 dark:text-slate-400 hover:text-teal-400 hover:translate-x-1 transition-all duration-300 text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
          <li><a href="/certificates/" class="block py-2 text-slate-500 dark:text-slate-400 hover:text-teal-400 hover:translate-x-1 transition-all duration-300 text-sm">Certificates</a></li>
          <li><a href="/achievements/" class="block py-2 text-slate-500 dark:text-slate-400 hover:text-teal-400 hover:translate-x-1 transition-all duration-300 text-sm">Achievements</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-5 text-[15px]">Our Services</h3>
        <ul class="space-y-1">
          {
            serviceList.slice(0, 6).map((service) => (
              <li>
                <a href={`/services/${service.slug}/`} class="block py-2 text-slate-500 dark:text-slate-400 hover:text-teal-400 hover:translate-x-1 transition-all duration-300 text-sm">
                  {service.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-5 text-[15px]">Contact Us</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{clinicInfo.address}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-teal-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            <a href={clinicInfo.phoneLink} class="text-slate-500 dark:text-slate-400 hover:text-teal-400 transition-colors text-sm">{clinicInfo.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-teal-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
            <a href={`mailto:${clinicInfo.email}`} class="text-slate-500 dark:text-slate-400 hover:text-teal-400 transition-colors text-sm">{clinicInfo.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <div class="text-slate-500 dark:text-slate-400 text-sm">
              <p>Tue - Sun</p>
              <p class="text-slate-500 dark:text-slate-400 text-xs mt-0.5">Morning: {clinicInfo.hours.tuesdayToSunday.morning}</p>
              <p class="text-slate-500 dark:text-slate-400 text-xs">Evening: {clinicInfo.hours.tuesdayToSunday.evening}</p>
              <p class="text-slate-500 dark:text-slate-400 text-xs mt-1">Monday: Closed</p>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <hr class="my-10 border-slate-800 dark:border-warm-800" />

    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-slate-600 dark:text-slate-500 text-sm">&copy; {year} {clinicInfo.copyright}. All rights reserved.</p>
      <p class="text-slate-600 dark:text-slate-500 text-sm">Designed with care for YourDentist Laser Dental Clinic</p>
    </div>
  </div>
</footer>

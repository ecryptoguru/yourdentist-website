---
import { doctor } from '@/lib/data';
---

<section class="section-padding bg-white dark:bg-warm-800 relative overflow-hidden" id="about">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-linear-to-l from-slate-50/50 dark:from-warm-700/30 to-transparent pointer-events-none"></div>
  <div class="glow-orb w-[300px] h-[300px] bg-teal-100/30 dark:bg-teal-800/15 top-[20%] right-[5%]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-12 gap-16 lg:gap-20 items-center">
      <!-- Image -->
      <div class="lg:col-span-5 relative reveal reveal-left">
        <div class="relative w-full aspect-4/5 max-w-md mx-auto lg:max-w-none">
          <div class="absolute inset-0 bg-teal-50 dark:bg-teal-900/30 rounded-2xl translate-x-5 translate-y-5 border border-teal-100 dark:border-teal-800 hidden sm:block"></div>
          <div class="absolute inset-0 bg-teal-50/40 dark:bg-teal-900/20 rounded-2xl overflow-hidden border border-slate-200/60 dark:border-warm-600 shadow-premium img-zoom">
            <img
              src="/images/about-clinic.jpg"
              alt="YourDentist Laser Dental Clinic in Bhubaneswar"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Experience badge -->
          <div class="float-badge absolute -bottom-5 -right-3 sm:-right-6 bg-white dark:bg-warm-800 rounded-xl shadow-premium-lg border border-slate-200/60 dark:border-warm-600 px-5 py-3.5 z-20 hidden sm:block">
            <p class="font-heading font-bold text-2xl text-gradient-teal leading-tight">10+ Years</p>
            <p class="text-slate-500 dark:text-warm-400 text-[11px] mt-0.5">of Dental Excellence</p>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="lg:col-span-7">
        <div class="reveal">
          <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">About Us</span>
        </div>
        <div class="reveal" style="transition-delay: 0.1s">
          <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-7 tracking-tight leading-[1.1]">
            Over a Decade of <span class="text-gradient-teal">Dental Excellence</span>
          </h2>
        </div>
        <div class="reveal" style="transition-delay: 0.2s">
          <div class="space-y-5 text-slate-600 dark:text-warm-300 leading-[1.75] text-[15px] mb-10">
            {doctor.bio.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.3s">
          <div class="flex flex-wrap gap-3">
            <a href="/certificates/" class="btn-premium border border-slate-300 dark:border-warm-600 text-slate-700 dark:text-warm-200 hover:bg-teal-50/80 dark:hover:bg-teal-900/30 hover:border-teal-300 dark:hover:border-teal-600 hover:text-teal-700 dark:hover:text-teal-400 gap-2 rounded-lg h-11 px-5 transition-all duration-300 inline-flex items-center justify-center">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22c5-2 8-7 8-13V5l-4-2H8L4 5v4c0 6 3 11 8 13z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
                Certificates
            </a>
            <a href="/achievements/" class="btn-premium border border-slate-300 dark:border-warm-600 text-slate-700 dark:text-warm-200 hover:bg-teal-50/80 dark:hover:bg-teal-900/30 hover:border-teal-300 dark:hover:border-teal-600 hover:text-teal-700 dark:hover:text-teal-400 gap-2 rounded-lg h-11 px-5 transition-all duration-300 inline-flex items-center justify-center">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526" />
                  <circle cx="12" cy="8" r="6" />
                </svg>
                Achievements
            </a>
            <a href="/gallery/" class="btn-premium border border-slate-300 dark:border-warm-600 text-slate-700 dark:text-warm-200 hover:bg-teal-50/80 dark:hover:bg-teal-900/30 hover:border-teal-300 dark:hover:border-teal-600 hover:text-teal-700 dark:hover:text-teal-400 gap-2 rounded-lg h-11 px-5 transition-all duration-300 inline-flex items-center justify-center">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="6 3 20 12 6 21 6 3" />
                </svg>
                Watch Videos
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

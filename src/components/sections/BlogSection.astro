---
import { getCollection } from 'astro:content';
import { formatDate } from '@/lib/format';

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featuredPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, 4);
---

<section class="section-padding bg-cream dark:bg-warm-900 relative" id="blog">
  <div class="absolute inset-0 bg-dot-grid-subtle opacity-20"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16 lg:mb-20 reveal">
      <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Our Blog</span>
      <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
        Dental Health <span class="text-gradient-teal">Insights</span>
      </h2>
      <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
        Expert advice, treatment guides, and tips for maintaining a healthy smile.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-6 mb-12">
      <!-- Featured Post -->
      <div class="reveal">
        <a href={`/blog/${featuredPost.id}/`}>
          <div class="group bg-white dark:bg-warm-800 rounded-xl overflow-hidden border border-slate-200/60 dark:border-warm-600 h-full shadow-premium hover:shadow-premium-hover transition-all duration-300">
            <div class="aspect-video bg-teal-50 dark:bg-teal-900/30 flex items-center justify-center border-b border-slate-100 dark:border-warm-700">
              <span class="text-slate-500 dark:text-warm-400 font-medium text-sm">Featured Image</span>
            </div>
            <div class="p-8">
              <span class="inline-block bg-teal-50 dark:bg-teal-900/40 text-teal-700 dark:text-teal-400 border border-teal-100 dark:border-teal-800 mb-4 font-medium text-xs px-2.5 py-0.5 rounded-full">
                {featuredPost.data.category}
              </span>
              <h3 class="font-heading text-xl font-semibold text-slate-900 dark:text-warm-100 mb-3 group-hover:text-teal-800 dark:group-hover:text-teal-400 transition-colors duration-300 leading-snug">
                {featuredPost.data.title}
              </h3>
              <p class="text-slate-500 dark:text-warm-400 text-[15px] leading-relaxed mb-5">{featuredPost.data.excerpt}</p>
              <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-warm-400">
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
                  </svg>
                  {formatDate(featuredPost.data.date)}
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                  </svg>
                  {featuredPost.data.readTime}
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>

      <!-- Recent Posts List -->
      <div class="flex flex-col gap-5">
        {recentPosts.map((post, i) => (
          <div class="stagger-item" style={`transition-delay: ${i * 0.1}s`}>
            <a href={`/blog/${post.id}/`}>
              <div class="group flex gap-5 bg-white dark:bg-warm-800 rounded-xl p-5 border border-slate-200/60 dark:border-warm-600 shadow-premium hover:shadow-premium-hover hover:-translate-y-0.5 transition-all duration-300">
                <div class="w-24 h-24 bg-teal-50 dark:bg-teal-900/30 rounded-lg shrink-0 flex items-center justify-center border border-slate-100 dark:border-warm-700">
                  <span class="text-slate-300 dark:text-warm-500 text-xs font-medium">IMG</span>
                </div>
                <div class="flex-1 min-w-0">
                  <span class="inline-block text-xs mb-2 border border-teal-200 dark:border-teal-700 text-teal-700 dark:text-teal-400 font-medium px-2 py-0.5 rounded-full">
                    {post.data.category}
                  </span>
                  <h4 class="font-heading font-semibold text-slate-900 dark:text-warm-100 mb-2 group-hover:text-teal-800 dark:group-hover:text-teal-400 transition-colors duration-300 line-clamp-2 text-[15px] leading-snug">
                    {post.data.title}
                  </h4>
                  <div class="flex items-center gap-3 text-xs text-slate-500 dark:text-warm-400">
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
                      </svg>
                      {formatDate(post.data.date, { month: 'short', day: 'numeric' })}
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                      </svg>
                      {post.data.readTime}
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center reveal">
      <a href="/blog/" class="inline-flex items-center gap-2 text-teal-700 dark:text-teal-400 font-medium text-sm hover:gap-3 transition-all duration-300 group">
        View All Articles
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

---
import { clinicInfo, serviceList } from '@/lib/data';
const today = new Date().toISOString().split('T')[0];
const maxDate = new Date(Date.now() + 90 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
---

<div id="booking-form-container">
  <form id="booking-form" class="max-w-xl mx-auto bg-white dark:bg-warm-800 rounded-xl p-6 sm:p-10 border border-slate-200/60 dark:border-warm-600 shadow-premium-lg" aria-label="Book an appointment" novalidate>
    <div class="space-y-5">
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700 dark:text-warm-200 mb-1.5">
          Full Name <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-warm-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
          <input id="name" type="text" required placeholder="Your full name" autocomplete="name" class="input-premium w-full pl-10 h-11 rounded-lg border border-slate-200 dark:border-warm-600 bg-white dark:bg-warm-700 px-3 py-2 text-sm text-slate-900 dark:text-warm-100 placeholder:text-slate-400 dark:placeholder:text-warm-500 focus:outline-none transition-all duration-300" />
          <p id="name-error" class="text-red-500 text-xs mt-1 hidden"></p>
        </div>
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-slate-700 dark:text-warm-200 mb-1.5">
          Phone Number <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-warm-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
          <input id="phone" type="tel" required placeholder="98765 43210" autocomplete="tel" inputmode="tel" maxlength="13" class="input-premium w-full pl-10 h-11 rounded-lg border border-slate-200 dark:border-warm-600 bg-white dark:bg-warm-700 px-3 py-2 text-sm text-slate-900 dark:text-warm-100 placeholder:text-slate-400 dark:placeholder:text-warm-500 focus:outline-none transition-all duration-300" />
          <p id="phone-error" class="text-red-500 text-xs mt-1 hidden"></p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="date" class="block text-sm font-medium text-slate-700 dark:text-warm-200 mb-1.5">Preferred Date</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-warm-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
            <input id="date" type="date" min={today} max={maxDate} class="input-premium w-full pl-10 h-11 rounded-lg border border-slate-200 dark:border-warm-600 bg-white dark:bg-warm-700 px-3 py-2 text-sm text-slate-900 dark:text-warm-100 focus:outline-none transition-all duration-300" />
          </div>
        </div>

        <div>
          <label for="treatment" class="block text-sm font-medium text-slate-700 dark:text-warm-200 mb-1.5">Treatment Type</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-warm-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h5a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2z" /></svg>
            <select id="treatment" class="input-premium w-full h-11 rounded-lg border border-slate-200 dark:border-warm-600 bg-white dark:bg-warm-700 pl-10 pr-3 py-2 text-sm text-slate-900 dark:text-warm-100 focus:outline-none transition-all duration-300 appearance-none">
              <option value="">Select treatment</option>
              {serviceList.map((s) => <option value={s.title}>{s.title}</option>)}
              <option value="General Checkup">General Checkup</option>
              <option value="Not Sure">Not Sure — Need Advice</option>
            </select>
          </div>
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-slate-700 dark:text-warm-200 mb-1.5">Additional Notes</label>
        <div class="relative">
          <svg class="absolute left-3 top-3.5 w-4 h-4 text-slate-400 dark:text-warm-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
          <textarea id="message" rows="3" maxlength="500" placeholder="Any specific concerns or symptoms..." class="input-premium w-full pl-10 rounded-lg border border-slate-200 dark:border-warm-600 bg-white dark:bg-warm-700 px-3 py-2 text-sm text-slate-900 dark:text-warm-100 placeholder:text-slate-400 dark:placeholder:text-warm-500 focus:outline-none transition-all duration-300 resize-none"></textarea>
        </div>
      </div>

      <button type="submit" class="btn-premium w-full bg-teal-700 hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-500 text-white gap-2 py-6 text-base rounded-lg font-medium transition-all duration-300 shadow-none hover:shadow-premium-lg inline-flex items-center justify-center group">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.086a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z" /><path d="m21.086 8.464-7.93 3.18a2 2 0 0 0-1.111 1.11l-3.18 7.931" /></svg>
        Request Appointment via WhatsApp
      </button>

      <p class="text-center text-sm text-slate-500 dark:text-warm-400">We will confirm your appointment within 2 hours during clinic hours.</p>
    </div>
  </form>

  <!-- Success state -->
  <div id="booking-success" class="hidden max-w-xl mx-auto text-center bg-white dark:bg-warm-800 rounded-xl p-8 sm:p-12 border border-teal-100/60 dark:border-teal-800/60 shadow-premium" role="status" aria-live="polite">
    <div class="w-14 h-14 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-full flex items-center justify-center mx-auto mb-5">
      <svg class="w-7 h-7 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.801 10A10 10 0 1 1 17 3.335" /><path d="m9 11 3 3L22 4" /></svg>
    </div>
    <h3 class="font-heading text-2xl font-semibold text-slate-900 dark:text-warm-100 mb-2">Request Sent!</h3>
    <p class="text-slate-500 dark:text-warm-400 mb-8 text-[15px] leading-relaxed">We've opened WhatsApp with your details. Dr. Arpita will confirm your appointment shortly.</p>
    <button id="book-again" type="button" class="border border-slate-300 dark:border-warm-600 text-slate-700 dark:text-warm-200 hover:bg-slate-100/80 dark:hover:bg-warm-700/80 hover:border-slate-400 dark:hover:border-warm-500 rounded-lg h-11 px-6 transition-all duration-300">Book Another Appointment</button>
  </div>
</div>

<script define:vars={{ whatsappBase: clinicInfo.whatsapp.split('?')[0] }}>
  const form = document.getElementById('booking-form');
  const success = document.getElementById('booking-success');
  const nameInput = document.getElementById('name');
  const phoneInput = document.getElementById('phone');
  const dateInput = document.getElementById('date');
  const treatmentSelect = document.getElementById('treatment');
  const messageInput = document.getElementById('message');
  const nameError = document.getElementById('name-error');
  const phoneError = document.getElementById('phone-error');

  function validatePhone(phone) {
    return /^[6-9]\d{9}$/.test(phone.replace(/\s/g, ''));
  }

  phoneInput?.addEventListener('input', () => {
    phoneInput.value = phoneInput.value.replace(/[^0-9\s]/g, '');
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    let hasError = false;

    if (!nameInput.value.trim()) {
      nameError.textContent = 'Name is required';
      nameError.classList.remove('hidden');
      hasError = true;
    } else {
      nameError.classList.add('hidden');
    }

    if (!phoneInput.value.trim()) {
      phoneError.textContent = 'Phone number is required';
      phoneError.classList.remove('hidden');
      hasError = true;
    } else if (!validatePhone(phoneInput.value)) {
      phoneError.textContent = 'Please enter a valid 10-digit phone number';
      phoneError.classList.remove('hidden');
      hasError = true;
    } else {
      phoneError.classList.add('hidden');
    }

    if (hasError) return;

    const text = encodeURIComponent(
      `*New Appointment Request*\n\n👤 Name: ${nameInput.value}\n📞 Phone: ${phoneInput.value}\n📅 Preferred Date: ${dateInput.value || 'Anytime'}\n🦷 Treatment: ${treatmentSelect.value || 'Not specified'}\n📝 Message: ${messageInput.value || 'None'}`
    );
    window.open(`${whatsappBase}?text=${text}`, '_blank');

    form.classList.add('hidden');
    success.classList.remove('hidden');
  });

  document.getElementById('book-again')?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    success.classList.add('hidden');
  });
</script>

---
import { clinicInfo } from '@/lib/data';

interface Props {
  hideHeader?: boolean;
}

const { hideHeader = false } = Astro.props;
---

<section class:list={[hideHeader ? 'py-0 bg-white dark:bg-warm-800 relative' : 'section-padding bg-white dark:bg-warm-800 relative']} id="contact">
  {!hideHeader && <div class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-slate-200 dark:via-warm-600 to-transparent"></div>}}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {!hideHeader && (
      <div class="text-center mb-16 lg:mb-20 reveal">
        <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Contact Us</span>
        <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
          Get in <span class="text-gradient-teal">Touch</span>
        </h2>
        <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
          Ready to start your journey to a healthier smile? Reach out to us today.
        </p>
      </div>
    )}

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
      <!-- Contact Info -->
      <div class="lg:col-span-5 reveal">
        <div class="space-y-5">
          <div class="bg-cream dark:bg-warm-700/50 rounded-xl p-7 sm:p-8 border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <h3 class="font-heading text-xl font-semibold text-slate-900 dark:text-warm-100 mb-7">Contact Information</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 dark:text-warm-400 mb-0.5 tracking-wide uppercase">Phone</p>
                  <a href={clinicInfo.phoneLink} class="text-slate-900 dark:text-warm-100 font-medium hover:text-teal-700 dark:hover:text-teal-400 transition-colors text-[15px]">{clinicInfo.phone}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 dark:text-warm-400 mb-0.5 tracking-wide uppercase">WhatsApp</p>
                  <a href={clinicInfo.whatsapp} target="_blank" rel="noopener noreferrer" class="text-slate-900 dark:text-warm-100 font-medium hover:text-teal-700 dark:hover:text-teal-400 transition-colors text-[15px]">{clinicInfo.phone}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 dark:text-warm-400 mb-0.5 tracking-wide uppercase">Email</p>
                  <a href={`mailto:${clinicInfo.email}`} class="text-slate-900 dark:text-warm-100 font-medium hover:text-teal-700 dark:hover:text-teal-400 transition-colors text-[15px]">{clinicInfo.email}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" /></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 dark:text-warm-400 mb-0.5 tracking-wide uppercase">Address</p>
                  <a href={clinicInfo.mapUrl} target="_blank" rel="noopener noreferrer" class="text-slate-900 dark:text-warm-100 font-medium hover:text-teal-700 dark:hover:text-teal-400 transition-colors text-[15px] leading-relaxed">{clinicInfo.address}</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 dark:text-warm-400 mb-0.5 tracking-wide uppercase">Opening Hours</p>
                  <div class="text-slate-900 dark:text-warm-100 text-[15px]">
                    <p>Tuesday - Sunday</p>
                    <p class="text-slate-500 dark:text-warm-400 text-sm">Morning: {clinicInfo.hours.tuesdayToSunday.morning}</p>
                    <p class="text-slate-500 dark:text-warm-400 text-sm">Evening: {clinicInfo.hours.tuesdayToSunday.evening}</p>
                    <p class="text-slate-500 dark:text-warm-400 text-sm mt-1">Monday: Closed</p>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <a href={clinicInfo.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-premium w-full bg-teal-700 hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-500 text-white gap-2 py-6 text-base rounded-lg font-medium transition-all duration-300 shadow-none hover:shadow-premium-lg inline-flex items-center justify-center">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
            Book Appointment via WhatsApp
        </a>
        </div>
      </div>

      <!-- Map -->
      <div class="lg:col-span-7 reveal reveal-right" style="transition-delay: 0.2s">
        <div class="bg-cream dark:bg-warm-700/50 rounded-xl p-3 sm:p-4 border border-slate-200/60 dark:border-warm-600 shadow-premium h-full min-h-[400px] lg:min-h-[500px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3679.124!2d85.8245!3d20.2961!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a1909b1e9b1e9b1%3A0x0!2sYourDentist%20Laser%20Dental%20Clinic!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin"
            width="100%"
            height="100%"
            style="border: 0; min-height: 400px; border-radius: 8px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="YourDentist Laser Dental Clinic Location on Google Maps"
            class="block"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

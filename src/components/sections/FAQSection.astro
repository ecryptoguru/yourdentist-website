---
import { faqItems } from '@/lib/data';

interface Props {
  customFaq?: { question: string; answer: string }[];
  title?: string;
  subtitle?: string;
}

const { customFaq, title = 'Frequently Asked Questions', subtitle = 'Have questions? We have answers.' } = Astro.props;
const items = customFaq ?? faqItems;
---

<section class="section-padding bg-cream dark:bg-warm-900 relative" id="faq">
  <div class="absolute inset-0 bg-dot-grid-subtle opacity-15"></div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-12 reveal">
      <div class="w-11 h-11 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center mx-auto mb-5">
        <svg class="w-5 h-5 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" />
        </svg>
      </div>
      <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mb-4 tracking-tight leading-[1.1]">{title}</h2>
      <p class="text-slate-500 dark:text-warm-400 max-w-xl mx-auto text-[15px] leading-relaxed">{subtitle}</p>
    </div>

    <div class="reveal" style="transition-delay: 0.1s">
      <div class="bg-white dark:bg-warm-800 rounded-xl border border-slate-200/60 dark:border-warm-600 shadow-premium overflow-hidden card-accent">
        {items.map((item, i) => (
          <details class="group border-b border-slate-100 dark:border-warm-700 last:border-b-0">
            <summary class="flex w-full items-center justify-between py-5 px-5 text-left text-slate-900 dark:text-warm-100 font-medium text-[15px] hover:text-teal-800 dark:hover:text-teal-400 transition-colors duration-200 cursor-pointer list-none">
              {item.question}
              <svg class="shrink-0 text-slate-400 dark:text-warm-500 transition-transform duration-200 group-open:rotate-180" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <div class="text-slate-600 dark:text-warm-300 text-[15px] leading-[1.7] pb-5 px-5">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

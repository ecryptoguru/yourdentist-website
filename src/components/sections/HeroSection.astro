---
import { clinicInfo, doctor } from '@/lib/data';
---

<section id="hero" class="relative min-h-screen flex items-center pt-36 pb-16 sm:pb-20 overflow-hidden bg-cream dark:bg-warm-900">
  <div class="absolute inset-0 bg-dot-grid-subtle opacity-40"></div>

  <!-- Glow orbs for premium ambient lighting -->
  <div class="glow-orb w-[400px] h-[400px] bg-teal-200/30 dark:bg-teal-800/15 top-[10%] right-[5%]"></div>
  <div class="glow-orb w-[300px] h-[300px] bg-amber-200/20 dark:bg-amber-800/10 bottom-[15%] left-[10%]"></div>

  <div class="absolute top-0 left-[15%] w-px h-32 bg-linear-to-b from-transparent via-slate-300 dark:via-warm-600 to-transparent opacity-40 hidden lg:block"></div>
  <div class="absolute bottom-0 right-[20%] w-px h-40 bg-linear-to-b from-transparent via-slate-300 dark:via-warm-600 to-transparent opacity-40 hidden lg:block"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Content -->
      <div class="order-2 lg:order-1 lg:col-span-7">
        <p class="hero-anim text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase mb-5 opacity-0" data-anim="label">
          Welcome to YourDentist
        </p>

        <div class="hero-anim w-12 h-[2px] bg-teal-600 rounded-full mb-6 opacity-0" data-anim="line" style="transform: scaleX(0); transform-origin: left;"></div>

        <h1 class="hero-anim font-heading text-5xl sm:text-6xl lg:text-[72px] font-semibold text-slate-900 dark:text-warm-100 leading-[1.05] mb-7 opacity-0 tracking-tight" data-anim="title">
          Your Smile,<br />
          <span class="text-gradient-teal">Our Passion</span>
        </h1>

        <p class="hero-anim text-slate-500 dark:text-warm-400 text-lg sm:text-xl mb-10 max-w-xl leading-relaxed opacity-0 speakable-summary" data-anim="desc">
          Experience advanced laser dental care in Bhubaneswar with <span class="text-slate-700 dark:text-warm-200 font-medium">Dr. Arpita Dash</span>. Painless treatments, beautiful results.
        </p>

        <div class="hero-anim flex flex-wrap gap-4 mb-14 opacity-0" data-anim="cta">
          <a href={clinicInfo.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-premium bg-teal-700 hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-500 text-white gap-2.5 px-8 py-6 text-base rounded-lg font-medium transition-all duration-300 shadow-none hover:shadow-premium-lg group inline-flex items-center justify-center">
            Book Appointment
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
          </a>
          <a href="/services/" class="border border-slate-300 dark:border-warm-600 text-slate-700 dark:text-warm-200 hover:bg-teal-50/80 dark:hover:bg-teal-900/30 hover:border-teal-300 dark:hover:border-teal-600 hover:text-teal-700 dark:hover:text-teal-400 px-8 py-6 text-base rounded-lg font-medium transition-all duration-300 inline-flex items-center justify-center">
            Explore Services
          </a>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-8 sm:gap-10" id="hero-stats">
          <div class="hero-anim flex items-center gap-3.5 opacity-0" data-anim="stat">
            <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center icon-glow transition-shadow duration-300">
              <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526" /><circle cx="12" cy="8" r="6" /></svg>
            </div>
            <div>
              <p class="font-heading font-semibold text-xl text-slate-900 dark:text-warm-100 leading-tight counter-value" data-count="10" data-suffix="+">10+</p>
              <p class="text-slate-500 dark:text-warm-400 text-[13px]">Years Experience</p>
            </div>
          </div>
          <div class="hero-anim flex items-center gap-3.5 opacity-0" data-anim="stat">
            <div class="w-10 h-10 bg-amber-50 dark:bg-amber-900/40 border border-amber-100 dark:border-amber-800 rounded-lg flex items-center justify-center icon-glow transition-shadow duration-300">
              <svg class="w-[18px] h-[18px] text-amber-700 dark:text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
            </div>
            <div>
              <p class="font-heading font-semibold text-xl text-slate-900 dark:text-warm-100 leading-tight counter-value" data-count="5000" data-suffix="+">5000+</p>
              <p class="text-slate-500 dark:text-warm-400 text-[13px]">Happy Patients</p>
            </div>
          </div>
          <div class="hero-anim flex items-center gap-3.5 opacity-0" data-anim="stat">
            <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center icon-glow transition-shadow duration-300">
              <svg class="w-[18px] h-[18px] text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h5a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2z" /></svg>
            </div>
            <div>
              <p class="font-heading font-semibold text-xl text-slate-900 dark:text-warm-100 leading-tight counter-value" data-count="12" data-suffix="">12</p>
              <p class="text-slate-500 dark:text-warm-400 text-[13px]">Services Offered</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Image Card -->
      <div class="order-1 lg:order-2 lg:col-span-5 relative hero-anim opacity-0" data-anim="card">
        <div class="relative w-full max-w-md mx-auto lg:max-w-none">
          <div class="absolute -top-4 -right-4 w-full h-full bg-teal-50 dark:bg-teal-900/30 rounded-2xl border border-teal-100 dark:border-teal-800 hidden sm:block"></div>
          <div class="absolute -bottom-3 -left-3 w-full h-full bg-teal-50/40 dark:bg-teal-900/20 rounded-2xl border border-teal-100/40 dark:border-teal-800/40 hidden sm:block"></div>

          <div class="relative bg-white dark:bg-warm-800 rounded-2xl shadow-premium-lg border border-slate-200/60 dark:border-warm-600 overflow-hidden">
            <div class="relative w-full aspect-square">
              <img src="/images/hero-welcome.jpeg" alt="Welcome to YourDentist Laser Dental Clinic in Bhubaneswar" class="w-full h-full object-cover" loading="eager" width="600" height="600" fetchpriority="high" />
            </div>
            <div class="h-1.5 bg-linear-to-r from-teal-600 via-teal-500 to-teal-400"></div>
          </div>

          <!-- Floating rating badge -->
          <div class="float-badge absolute -bottom-5 -left-5 sm:-left-8 bg-white dark:bg-warm-800 rounded-xl shadow-premium-lg border border-slate-200/60 dark:border-warm-600 px-5 py-3.5 hidden sm:flex items-center gap-3 z-20">
            <div class="w-10 h-10 bg-amber-50 dark:bg-amber-900/40 border border-amber-100 dark:border-amber-800 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-500 dark:text-amber-400" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
            </div>
            <div>
              <p class="font-heading font-bold text-lg text-slate-900 dark:text-warm-100 leading-tight">4.9</p>
              <p class="text-slate-500 dark:text-warm-400 text-[11px]">150+ Reviews</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <button
      id="hero-scroll-indicator"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 cursor-pointer bg-transparent border-none group"
      aria-label="Scroll to explore"
    >
      <span class="text-slate-400 dark:text-warm-500 text-xs tracking-wide">Scroll to explore</span>
      <svg class="w-5 h-5 text-slate-400 dark:text-warm-500 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </button>
  </div>
</section>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    document.querySelectorAll('[data-anim]').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  } else {
    // Set initial transforms immediately to prevent flash
    document.querySelectorAll('[data-anim="title"], [data-anim="desc"], [data-anim="cta"], [data-anim="label"]').forEach((el) => {
      (el as HTMLElement).style.transform = 'translateY(30px)';
    });
    document.querySelectorAll('[data-anim="card"]').forEach((el) => {
      (el as HTMLElement).style.transform = 'translateX(60px)';
    });
    document.querySelectorAll('[data-anim="stat"]').forEach((el) => {
      (el as HTMLElement).style.transform = 'translateY(20px)';
    });

    // Stagger stats
    const stats = document.querySelectorAll('[data-anim="stat"]');
    stats.forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.12}s`;
    });

    // Hero entrance animation with CSS transitions
    const animElements = document.querySelectorAll('[data-anim]');
    const delays: Record<string, number> = { label: 200, line: 400, title: 600, desc: 900, cta: 1100, card: 700, stat: 1300 };

    animElements.forEach((el) => {
      const htmlEl = el as HTMLElement;
      const type = htmlEl.dataset.anim;
      const delay = (type && delays[type]) || 0;
      setTimeout(() => {
        htmlEl.style.transition = 'opacity 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
        htmlEl.style.opacity = '1';
        if (type === 'line') {
          htmlEl.style.transform = 'scaleX(1)';
        } else if (type === 'card') {
          htmlEl.style.transform = 'translateX(0)';
        } else {
          htmlEl.style.transform = 'translateY(0)';
        }
      }, delay);
    });
  }

  // Scroll indicator
  document.getElementById('hero-scroll-indicator')?.addEventListener('click', () => {
    document.getElementById('about')?.scrollIntoView({ behavior: 'smooth' });
  });

  // Animated counter for stats
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.count || '0', 10);
    const suffix = el.dataset.suffix || '';
    const duration = 1500;
    const start = performance.now();
    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(eased * target);
      el.textContent = current.toLocaleString('en-IN') + suffix;
      if (progress < 1) requestAnimationFrame(update);
      else el.textContent = target.toLocaleString('en-IN') + suffix;
    }
    requestAnimationFrame(update);
  }

  // Trigger counter animation after hero entrance
  setTimeout(() => {
    document.querySelectorAll<HTMLElement>('.counter-value').forEach((el) => animateCounter(el));
  }, 1400);
</script>

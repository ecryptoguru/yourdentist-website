---
import { testimonials, clinicInfo } from '@/lib/data';
---

<section class="section-padding-sm bg-cream dark:bg-warm-900 relative" id="reviews">
  <div class="absolute inset-0 bg-dot-grid-subtle opacity-15"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-12 reveal">
      <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mb-5 tracking-tight leading-[1.1]">
        Trusted by <span class="text-gradient-teal">5,000+ Patients</span>
      </h2>
      <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
        YourDentist Laser Dental Clinic is one of the most trusted dental practices in Bhubaneswar.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      {['10+ Years Experience', '4.9 Rating', 'Sterilised Equipment', 'Timely Appointments'].map((label, i) => (
        <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
          <div class="bg-white dark:bg-warm-800 rounded-xl p-5 border border-slate-200/60 dark:border-warm-600 text-center shadow-premium hover:shadow-premium-hover hover-lift transition-all duration-300 card-accent">
            <div class="w-9 h-9 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-4 h-4 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.801 10A10 10 0 1 1 17 3.335" /><path d="m9 11 3 3L22 4" /></svg>
            </div>
            <p class="font-medium text-slate-900 dark:text-warm-100 text-sm">{label}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="reveal" style="transition-delay: 0.3s">
      <div class="bg-white dark:bg-warm-800 rounded-xl p-6 sm:p-8 border border-slate-200/60 dark:border-warm-600 shadow-premium">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-4">
            <div class="flex -space-x-2">
              {testimonials.slice(0, 4).map((t) => (
                <div class="relative w-9 h-9 rounded-full border-2 border-white dark:border-warm-800 shadow-sm overflow-hidden bg-teal-50 dark:bg-teal-900/40">
                  {t.photo ? (
                    <img src={t.photo} alt={t.name} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                  ) : null}
                  <span class={`absolute inset-0 items-center justify-center text-[11px] font-bold text-teal-700 dark:text-teal-400 ${t.photo ? 'hidden' : 'flex'}`}>{t.initials}</span>
                </div>
              ))}
            </div>
            <div>
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-3.5 h-3.5 fill-amber-400 text-amber-400" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                  </svg>
                ))}
                <span class="text-sm font-semibold text-slate-900 dark:text-warm-100 ml-1">4.9</span>
              </div>
              <p class="text-slate-500 dark:text-warm-400 text-xs">Based on 150+ reviews</p>
            </div>
          </div>

          <div class="flex items-center gap-2 text-slate-500 dark:text-warm-400 text-sm">
            <svg class="w-4 h-4 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span>{clinicInfo.address}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

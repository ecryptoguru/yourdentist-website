---
import { testimonials } from '@/lib/data';
---

<section class="section-padding bg-cream dark:bg-warm-900 relative" id="testimonials">
  <div class="absolute inset-0 bg-dot-grid-subtle opacity-20"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16 lg:mb-20 reveal">
      <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Testimonials</span>
      <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
        What Our <span class="text-gradient-teal">Patients Say</span>
      </h2>
      <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
        Real stories from real patients who trust us with their smiles.
      </p>
    </div>

    <div class="reveal" style="transition-delay: 0.2s">
      <div class="relative overflow-hidden">
        <div id="testimonials-track" class="flex transition-transform duration-500 ease-out">
          {testimonials.map((testimonial) => (
            <div class="pl-4 shrink-0 w-full md:w-1/2 lg:w-1/3">
              <div class="bg-white dark:bg-warm-800 rounded-xl p-8 border border-slate-200/60 dark:border-warm-600 h-full flex flex-col shadow-premium hover:shadow-premium-hover hover-lift card-shimmer">
                <svg class="w-8 h-8 text-teal-100 dark:text-teal-800 mb-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 0 .25 0 .25.25v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" /></svg>
                <p class="text-slate-600 dark:text-warm-300 text-[15px] leading-[1.7] flex-1 mb-6">&ldquo;{testimonial.text}&rdquo;</p>
                <div class="flex items-center gap-1 mb-5">
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <svg class="w-3.5 h-3.5 fill-amber-400 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                  ))}
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-full overflow-hidden flex items-center justify-center">
                    {testimonial.photo ? (
                      <img src={testimonial.photo} alt={testimonial.name} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    ) : null}
                    <span class={`bg-teal-700 dark:bg-teal-600 text-white text-xs font-semibold w-full h-full items-center justify-center ${testimonial.photo ? 'hidden' : 'flex'}`}>{testimonial.initials}</span>
                  </div>
                  <div>
                    <p class="font-medium text-slate-900 dark:text-warm-100 text-sm">{testimonial.name}</p>
                    <p class="text-slate-500 dark:text-warm-400 text-xs">Verified Patient</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex justify-center items-center gap-3 mt-10">
        <button id="testimonials-prev" aria-label="Previous testimonials" class="relative left-0 translate-y-0 bg-white dark:bg-warm-800 border border-slate-200/80 dark:border-warm-600 hover:bg-teal-50 dark:hover:bg-teal-900/30 hover:border-teal-200 dark:hover:border-teal-600 h-10 w-10 rounded-lg shadow-premium transition-all duration-300 flex items-center justify-center">
          <svg class="w-5 h-5 text-slate-600 dark:text-warm-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        </button>
        <div id="testimonials-dots" class="flex items-center gap-2"></div>
        <button id="testimonials-next" aria-label="Next testimonials" class="relative right-0 translate-y-0 bg-white dark:bg-warm-800 border border-slate-200/80 dark:border-warm-600 hover:bg-teal-50 dark:hover:bg-teal-900/30 hover:border-teal-200 dark:hover:border-teal-600 h-10 w-10 rounded-lg shadow-premium transition-all duration-300 flex items-center justify-center">
          <svg class="w-5 h-5 text-slate-600 dark:text-warm-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ count: testimonials.length }}>
  const track = document.getElementById('testimonials-track');
  const dotsContainer = document.getElementById('testimonials-dots');
  let index = 0;

  function getVisibleCount() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 768) return 2;
    return 1;
  }

  function getMaxIndex() {
    return Math.max(0, count - getVisibleCount());
  }

  function update() {
    if (!track) return;
    const visible = getVisibleCount();
    const maxIndex = getMaxIndex();
    if (index > maxIndex) index = maxIndex;
    const slideWidth = track.children[0]?.getBoundingClientRect().width || 0;
    track.style.transform = `translateX(-${index * slideWidth}px)`;
    updateDots();
  }

  function updateDots() {
    if (!dotsContainer) return;
    const maxIndex = getMaxIndex();
    dotsContainer.innerHTML = '';
    for (let i = 0; i <= maxIndex; i++) {
      const dot = document.createElement('button');
      dot.className = `h-2 rounded-full transition-all duration-300 ${i === index ? 'w-6 bg-teal-700 dark:bg-teal-500' : 'w-2 bg-slate-300 dark:bg-warm-600 hover:bg-slate-400 dark:hover:bg-warm-500'}`;
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
      dot.addEventListener('click', () => {
        index = i;
        update();
      });
      dotsContainer.appendChild(dot);
    }
  }

  document.getElementById('testimonials-next')?.addEventListener('click', () => {
    const maxIndex = getMaxIndex();
    index = index >= maxIndex ? 0 : index + 1;
    update();
  });

  document.getElementById('testimonials-prev')?.addEventListener('click', () => {
    const maxIndex = getMaxIndex();
    index = index <= 0 ? maxIndex : index - 1;
    update();
  });

  let resizeTicking = false;
  window.addEventListener('resize', () => {
    if (resizeTicking) return;
    resizeTicking = true;
    requestAnimationFrame(() => {
      update();
      resizeTicking = false;
    });
  });
  update();

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;

  track?.parentElement?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  track?.parentElement?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) < 50) return;
    const maxIndex = getMaxIndex();
    if (diff > 0) {
      index = index >= maxIndex ? 0 : index + 1;
    } else {
      index = index <= 0 ? maxIndex : index - 1;
    }
    update();
  }, { passive: true });

  // Auto-scroll (pause on hover and when tab hidden)
  let autoScrollTimer = null;
  let isHovered = false;

  function startAutoScroll() {
    stopAutoScroll();
    autoScrollTimer = setInterval(() => {
      if (document.hidden || isHovered) return;
      const maxIndex = getMaxIndex();
      index = index >= maxIndex ? 0 : index + 1;
      update();
    }, 5000);
  }

  function stopAutoScroll() {
    if (autoScrollTimer) {
      clearInterval(autoScrollTimer);
      autoScrollTimer = null;
    }
  }

  const carousel = document.querySelector('#testimonials-track')?.parentElement;
  carousel?.addEventListener('mouseenter', () => { isHovered = true; });
  carousel?.addEventListener('mouseleave', () => { isHovered = false; });

  startAutoScroll();
</script>

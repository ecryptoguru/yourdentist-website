---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { doctor } from '@/lib/data';
---

<BaseLayout
  title="About Dr. Arpita Dash | Best Dentist in Bhubaneswar | YourDentist"
  description={`Meet Dr. Arpita Dash, a dental surgeon with ${doctor.experience}+ years of experience in Bhubaneswar. Specializing in root canal, orthodontics, implants, and aesthetic dentistry. 5,000+ happy patients.`}
>
  <Header />
  <main class="flex-1 pt-36">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="text-center mb-16 lg:mb-20 reveal">
        <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">About Us</span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-[56px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
          Meet Dr. <span class="text-gradient-teal">Arpita Dash</span>
        </h1>
      </div>

      <div class="grid lg:grid-cols-12 gap-16 lg:gap-20 items-center mb-24">
        <div class="lg:col-span-5 reveal reveal-left">
          <div class="relative aspect-4/5 max-w-md mx-auto lg:max-w-none">
            <div class="absolute inset-0 bg-teal-50 dark:bg-teal-900/30 rounded-2xl translate-x-5 translate-y-5 border border-teal-100 dark:border-teal-800 hidden sm:block"></div>
            <div class="absolute inset-0 bg-teal-50/40 dark:bg-teal-900/20 rounded-2xl overflow-hidden border border-slate-200/60 dark:border-warm-600 shadow-premium">
              <img src="/images/about-clinic.jpg" alt="YourDentist Laser Dental Clinic in Bhubaneswar" class="w-full h-full object-cover" loading="eager" />
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="reveal">
            <h2 class="font-heading text-3xl font-semibold text-slate-900 dark:text-warm-100 mb-6 tracking-tight leading-[1.15]">Dedicated to Your Smile</h2>
          </div>
          <div class="reveal" style="transition-delay: 0.1s">
            <div class="space-y-5 text-slate-600 dark:text-warm-300 leading-[1.75] text-[15px] mb-8">
              {doctor.bio.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
          <div class="reveal" style="transition-delay: 0.2s">
            <p class="text-teal-700 dark:text-teal-400 font-medium italic text-[15px] leading-relaxed border-l-2 border-teal-200 dark:border-teal-700 pl-5">
              &ldquo;{doctor.philosophy}&rdquo;
            </p>
          </div>
        </div>
      </div>

      <div class="text-center mb-14 reveal">
        <h2 class="font-heading text-3xl sm:text-[36px] font-semibold text-slate-900 dark:text-warm-100 mb-4 tracking-tight leading-[1.1]">Specializations</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-24">
        {doctor.specializations.map((spec, i) => (
          <div class="stagger-item" style={`transition-delay: ${i * 0.1}s`}>
            <div class="bg-white dark:bg-warm-800 rounded-xl p-6 border border-slate-200/60 dark:border-warm-600 flex items-center gap-4 shadow-premium hover:shadow-premium-hover transition-all duration-300 hover:-translate-y-0.5">
              <div class="w-11 h-11 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M8 14s1.5 2 4 2 4-2 4-2" /><line x1="9" x2="9.01" y1="9" y2="9" /><line x1="15" x2="15.01" y1="9" y2="9" /></svg>
              </div>
              <p class="font-medium text-slate-900 dark:text-warm-100 text-[15px]">{spec}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mb-14 reveal">
        <h2 class="font-heading text-3xl sm:text-[36px] font-semibold text-slate-900 dark:text-warm-100 mb-4 tracking-tight leading-[1.1]">By The Numbers</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div class="reveal">
          <div class="text-center p-8 sm:p-10 bg-white dark:bg-warm-800 rounded-xl border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <svg class="w-8 h-8 text-teal-700 dark:text-teal-400 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526" /><circle cx="12" cy="8" r="6" /></svg>
            <p class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100">{doctor.experience}</p>
            <p class="text-slate-500 dark:text-warm-400 mt-2 text-sm">Years Experience</p>
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.1s">
          <div class="text-center p-8 sm:p-10 bg-white dark:bg-warm-800 rounded-xl border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <svg class="w-8 h-8 text-teal-700 dark:text-teal-400 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
            <p class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100">{doctor.patients}</p>
            <p class="text-slate-500 dark:text-warm-400 mt-2 text-sm">Happy Patients</p>
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.2s">
          <div class="text-center p-8 sm:p-10 bg-white dark:bg-warm-800 rounded-xl border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <svg class="w-8 h-8 text-teal-700 dark:text-teal-400 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h5a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2z" /></svg>
            <p class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100">{doctor.procedures}</p>
            <p class="text-slate-500 dark:text-warm-400 mt-2 text-sm">Procedures Done</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

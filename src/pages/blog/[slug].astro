---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection, render } from 'astro:content';
import { doctor, clinicInfo } from '@/lib/data';
import { formatDate } from '@/lib/format';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find((p) => p.id === slug);

if (!post) {
  return Astro.redirect('/404');
}

const data = post.data;
const { Content } = await render(post);
const relatedPosts = posts.filter((p) => p.id !== slug && p.data.category === data.category).slice(0, 2);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.excerpt,
  image: 'https://www.yourdentistdentalclinic.com/images/clinic.jpg',
  datePublished: data.date,
  dateModified: data.lastUpdated || data.date,
  author: { '@type': 'Person', name: doctor.name, jobTitle: 'Dental Surgeon & Smile Specialist', url: 'https://www.yourdentistdentalclinic.com/about/' },
  publisher: { '@type': 'Organization', name: clinicInfo.name, logo: { '@type': 'ImageObject', url: 'https://www.yourdentistdentalclinic.com/images/clinic.jpg' } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://www.yourdentistdentalclinic.com/blog/${slug}/` },
};
---

<BaseLayout title={`${data.title} | YourDentist Bhubaneswar`} description={data.excerpt} type="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  </Fragment>
  <Header />
  <main class="flex-1 pt-36">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Blog', href: '/blog/' }, { name: data.title, href: `/blog/${slug}/` }]} />
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <article>
        <div class="reveal">
          <div class="aspect-video bg-teal-50 dark:bg-teal-900/30 rounded-xl flex items-center justify-center mb-8 border border-slate-200/40 dark:border-warm-600 shadow-premium">
            <span class="inline-block bg-white/90 dark:bg-warm-100/90 text-teal-700 dark:text-teal-400 border border-teal-100 dark:border-teal-800 px-4 py-1.5 font-medium rounded-full">{data.category}</span>
          </div>
        </div>

        <div class="reveal" style="transition-delay: 0.1s">
          <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100 mb-5 tracking-tight leading-[1.15]">{data.title}</h1>
        </div>

        <div class="reveal" style="transition-delay: 0.15s">
          <div class="flex flex-wrap items-center gap-4 mb-8">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-teal-50 dark:bg-teal-900/40 border border-teal-100 dark:border-teal-800 rounded-full flex items-center justify-center">
                <span class="bg-teal-50 dark:bg-teal-900/40 text-teal-700 dark:text-teal-400 text-sm font-bold">AD</span>
              </div>
              <div>
                <p class="font-medium text-slate-900 dark:text-warm-100 text-sm">{doctor.name}</p>
                <p class="text-slate-500 dark:text-warm-400 text-xs">Dental Surgeon & Smile Specialist</p>
              </div>
            </div>
            <div class="w-px h-8 bg-slate-200 dark:bg-warm-600 hidden sm:block"></div>
            <div class="flex items-center gap-3 text-sm text-slate-500 dark:text-warm-400">
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                {formatDate(data.date, { month: 'long', day: 'numeric', year: 'numeric' })}
              </span>
              {data.lastUpdated && (
                <span class="flex items-center gap-1.5 text-xs text-slate-400 dark:text-warm-500">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56" /><path d="M21 3v6h-6" /></svg>
                  Updated {formatDate(data.lastUpdated, { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              )}
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                {data.readTime}
              </span>
            </div>
          </div>
        </div>

        <div class="reveal" style="transition-delay: 0.2s">
          <div class="prose prose-slate dark:prose-invert max-w-none mb-12">
            <Content />
          </div>
        </div>

        <div class="reveal" style="transition-delay: 0.25s">
          <div class="bg-linear-to-br from-teal-50/80 to-emerald-50/40 dark:from-teal-900/30 dark:to-emerald-900/20 rounded-xl p-6 sm:p-7 border border-teal-100/50 dark:border-teal-800/50 mb-12">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-teal-100 dark:bg-teal-800/60 border border-teal-200 dark:border-teal-700 rounded-full flex items-center justify-center shrink-0">
                <span class="text-teal-700 dark:text-teal-400 font-bold text-lg">AD</span>
              </div>
              <div>
                <h3 class="font-heading text-base font-semibold text-slate-900 dark:text-warm-100 mb-1">About {doctor.name}</h3>
                <p class="text-slate-600 dark:text-warm-300 text-sm leading-relaxed mb-3">
                  Dr. Arpita Dash is a Dental Surgeon & Smile Specialist with {doctor.experience} years of experience in Bhubaneswar, specializing in root canal treatment, orthodontics, dental implants, and aesthetic dentistry. She has treated over {doctor.patients} patients with a 4.9-star rating.
                </p>
                <a href="/about/" class="inline-flex items-center gap-1.5 text-teal-700 dark:text-teal-400 font-medium text-sm hover:gap-2.5 transition-all duration-300">
                  Learn more about Dr. Arpita Dash
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal" style="transition-delay: 0.3s">
          <div class="bg-teal-50/60 dark:bg-teal-900/20 rounded-xl p-6 sm:p-7 border border-teal-100/60 dark:border-teal-800/60 mb-12">
            <h3 class="font-heading text-lg font-semibold text-slate-900 dark:text-warm-100 mb-2">Need Professional Advice?</h3>
            <p class="text-slate-600 dark:text-warm-300 text-[15px] mb-5 leading-relaxed">Schedule a consultation with Dr. Arpita Dash to discuss your dental concerns.</p>
            <a href="/contact/" class="inline-flex items-center gap-2 text-teal-700 dark:text-teal-400 font-medium text-sm hover:gap-3 transition-all duration-300 group">
              Book a Consultation
              <svg class="w-4 h-4 rotate-180 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7" /><path d="M19 12H5" /></svg>
            </a>
          </div>
        </div>

        {relatedPosts.length > 0 && (
          <div class="reveal" style="transition-delay: 0.4s">
            <h3 class="font-heading text-xl font-semibold text-slate-900 dark:text-warm-100 mb-5">Related Articles</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.id}/`}>
                  <div class="bg-white dark:bg-warm-800 rounded-xl p-5 border border-slate-200/60 dark:border-warm-600 hover:border-teal-200/80 dark:hover:border-teal-600/80 hover:shadow-premium transition-all duration-300 shadow-premium">
                    <span class="inline-block text-xs mb-2 border border-teal-200 dark:border-teal-700 text-teal-700 dark:text-teal-400 font-medium px-2 py-0.5 rounded-full">{related.data.category}</span>
                    <h4 class="font-medium text-slate-900 dark:text-warm-100 text-sm line-clamp-2 leading-snug">{related.data.title}</h4>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </div>

  </main>
  <Footer />
</BaseLayout>

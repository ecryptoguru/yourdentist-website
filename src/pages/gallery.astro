---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import GalleryGrid from '@/components/sections/GalleryGrid.astro';
---

<BaseLayout
  title="Dental Clinic Gallery in Bhubaneswar | YourDentist Laser Dental Clinic"
  description="Explore our modern dental clinic facilities and advanced equipment in Bhubaneswar. See why YourDentist Laser Dental Clinic is trusted by 5,000+ patients for premium dental care."
>
  <Header />
  <main class="flex-1 pt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="text-center mb-16 lg:mb-20 reveal">
        <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Gallery</span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-[56px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
          Our <span class="text-gradient-teal">Clinic</span>
        </h1>
        <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
          Take a look at our modern facilities designed for your comfort and care.
        </p>
      </div>
      <GalleryGrid />
    </div>
  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import ReviewsSection from '@/components/sections/ReviewsSection.astro';
import AboutSection from '@/components/sections/AboutSection.astro';
import ServicesSection from '@/components/sections/ServicesSection.astro';
import BeforeAfterSection from '@/components/sections/BeforeAfterSection.astro';
import TestimonialsSection from '@/components/sections/TestimonialsSection.astro';
import GallerySection from '@/components/sections/GallerySection.astro';
import TalksSection from '@/components/sections/TalksSection.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import BookingForm from '@/components/sections/BookingForm.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import { areasServed, aboutUsContent } from '@/lib/data';
---

<BaseLayout title="Best Dental Clinic in Bhubaneswar | Laser Dentistry | YourDentist" description="Top-rated dental clinic in Bhubaneswar led by Dr. Arpita Dash. Painless root canal, braces, dental implants, laser dentistry & smile designing. 5,000+ happy patients. Book today!">
  <Header />
  <main class="flex-1">
    <HeroSection />
    <ReviewsSection />
    <section class="section-padding bg-cream dark:bg-warm-900 relative overflow-hidden" id="clinic-about">
      <div class="glow-orb w-[300px] h-[300px] bg-teal-100/30 dark:bg-teal-800/15 top-[15%] left-[5%]"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center mb-12 reveal">
          <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">About Us</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-8 tracking-tight leading-[1.1]">
            Redefining Your <span class="text-gradient-teal">Dental Experience</span>
          </h2>
        </div>
        <div class="space-y-6 reveal">
          {aboutUsContent.paragraphs.map((paragraph) => (
            <p class="text-slate-600 dark:text-warm-300 text-[15px] leading-[1.8] text-center max-w-3xl mx-auto">{paragraph}</p>
          ))}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-12 reveal">
          <div class="text-center p-6 rounded-2xl bg-white dark:bg-warm-800 border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <div class="w-12 h-12 bg-teal-50 dark:bg-teal-900/40 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.5 2 6 4.5 6 8c0 2.5 1.5 5 3 7.5C10.5 18 11 20 12 20s1.5-2 3-4.5c1.5-2.5 3-5 3-7.5 0-3.5-2.5-6-6-6z" /><path d="M12 8v4" /><circle cx="12" cy="8" r="1.5" fill="currentColor" stroke="none" /></svg>
            </div>
            <h3 class="font-heading font-semibold text-slate-900 dark:text-warm-100 text-sm mb-2">Painless Treatments</h3>
            <p class="text-slate-500 dark:text-warm-400 text-[13px] leading-relaxed">State-of-the-art equipment and laser technology for minimal discomfort.</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-white dark:bg-warm-800 border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <div class="w-12 h-12 bg-teal-50 dark:bg-teal-900/40 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path d="m9 12 2 2 4-4" /></svg>
            </div>
            <h3 class="font-heading font-semibold text-slate-900 dark:text-warm-100 text-sm mb-2">Advanced Technology</h3>
            <p class="text-slate-500 dark:text-warm-400 text-[13px] leading-relaxed">Cutting-edge tools for precision Root Canal, Aesthetic Dentistry & Orthodontics.</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-white dark:bg-warm-800 border border-slate-200/60 dark:border-warm-600 shadow-premium">
            <div class="w-12 h-12 bg-teal-50 dark:bg-teal-900/40 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-teal-700 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4" /><path d="M12 2L4 7v6c0 5.5 3.5 10 8 11 4.5-1 8-5.5 8-11V7l-8-5z" /></svg>
            </div>
            <h3 class="font-heading font-semibold text-slate-900 dark:text-warm-100 text-sm mb-2">Sterilisation Standards</h3>
            <p class="text-slate-500 dark:text-warm-400 text-[13px] leading-relaxed">Autoclaves, single-use disposables, and advanced disinfection practices.</p>
          </div>
        </div>
      </div>
    </section>
    <AboutSection />
    <ServicesSection />
    <BeforeAfterSection />
    <TestimonialsSection />
    <GallerySection />
    <TalksSection />
    <FAQSection />
    <section class="section-padding bg-white dark:bg-warm-800" aria-label="Areas served in Bhubaneswar">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 reveal">
          <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Areas We Serve</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
            Trusted Dental Clinic Across <span class="text-gradient-teal">Bhubaneswar</span>
          </h2>
          <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
            YourDentist Laser Dental Clinic is conveniently located in Bomikhal, serving patients from all across Bhubaneswar and nearby areas.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-3 reveal">
          {areasServed.map((area) => (
            <span class="px-4 py-2 rounded-full bg-teal-50 dark:bg-teal-900/40 text-teal-700 dark:text-teal-400 text-sm font-medium border border-teal-100 dark:border-teal-800 hover:bg-teal-100 dark:hover:bg-teal-800/60 transition-colors">
              {area}
            </span>
          ))}
        </div>
      </div>
    </section>
    <section class="section-padding bg-cream dark:bg-warm-900 relative" id="appointment">
      <div class="absolute inset-0 bg-dot-grid-subtle opacity-20"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center mb-16 reveal">
          <span class="text-teal-700 dark:text-teal-400 font-medium text-sm tracking-[0.15em] uppercase">Appointment</span>
          <h2 class="font-heading text-4xl sm:text-[42px] font-semibold text-slate-900 dark:text-warm-100 mt-4 mb-5 tracking-tight leading-[1.1]">
            Book Your <span class="text-gradient-teal">Visit</span>
          </h2>
          <p class="text-slate-500 dark:text-warm-400 max-w-2xl mx-auto text-[15px] leading-relaxed">
            Fill in your details and we will confirm your appointment via WhatsApp within 2 hours.
          </p>
        </div>
        <BookingForm />
      </div>
    </section>
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
